# 단순한 샘플 큐브 (Sample Cube)
# 사용자 3D 모델 불러오기(import) 테스트용

# 정점 (Vertices)
v  1.0  1.0 -1.0
v  1.0 -1.0 -1.0
v  1.0  1.0  1.0
v  1.0 -1.0  1.0
v -1.0  1.0 -1.0
v -1.0 -1.0 -1.0
v -1.0  1.0  1.0
v -1.0 -1.0  1.0

# 텍스처 좌표 (Texture Coordinates)
vt 0.0000 1.0000
vt 0.0000 0.0000
vt 1.0000 1.0000
vt 1.0000 0.0000

# 법선 (Normals)
vn  0.0  0.0 -1.0
vn  0.0  0.0  1.0
vn  1.0  0.0  0.0
vn -1.0  0.0  0.0
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0

# 면 (Faces) : 앞, 뒤, 좌, 우, 위, 아래
f 5 7 8 6
f 1 3 4 2
f 1 5 6 2
f 3 7 8 4
f 1 5 7 3
f 2 6 8 4
